ALTASTATA_ACCOUNT_ID=amazon.rsa.bob123
ALTASTATA_DISPLAY_NAME=bob123
ALTASTATA_PASSWORD=123
ALTASTATA_ACCOUNT_DIR=~/.altastata/accounts/amazon.rsa.bob123

ALTASTATA_GRPC_HOST=127.0.0.1
ALTASTATA_GRPC_PORT=9877
ALTASTATA_GRPC_SECURE=false
ALTASTATA_GRPC_AUTO_START_SERVER=true
ALTASTATA_GRPC_SETUP_PORT=9880
# Optional override; defaults to "bob123" from account id.
# ALTASTATA_GRPC_USER_NAME=bob123

